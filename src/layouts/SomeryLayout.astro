---
import "../styles/somery.css";
import SomeryHeader from "../components/SomeryHeader.astro";
import SomeryFooter from "../components/SomeryFooter.astro";

interface Props {
  title: string;
  description: string;
  activePage?: "home" | "releases";
  ogTitle?: string;
  ogDescription?: string;
  twitterTitle?: string;
  twitterDescription?: string;
}

const {
  title,
  description,
  activePage = "home",
  ogTitle = title,
  ogDescription = description,
  twitterTitle = ogTitle,
  twitterDescription = ogDescription,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={twitterTitle} />
    <meta name="twitter:description" content={twitterDescription} />
  </head>

  <body>
    <SomeryHeader activePage={activePage} />
    <main>
      <slot />
    </main>
    <SomeryFooter />
    <script is:inline src="/somery/main.js" defer></script>
  </body>
</html>
